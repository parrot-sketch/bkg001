{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "baseUrl": "..",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@domain/*": ["./domain/*"],
      "@/*": ["./*"]
    },
    "noCheck": true,
    "noEmit": true
  },
  "include": [
    "../next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["../node_modules"]
}
